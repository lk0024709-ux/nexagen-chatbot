# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Hugging Face (optional)
HF_API_TOKEN=your_huggingface_api_token_here

# Groq (Llama 3.3 default model)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Microsoft Azure OpenAI (GPT-5 via Microsoft SDK)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5

# GitHub Token (for Microsoft SDK authentication fallback)
GITHUB_TOKEN=your_github_personal_access_token_here

# Model Configuration
GPT_MODEL=gpt-5
PRIMARY_AI=gpt-5
FALLBACK_MODEL=llama3-70b
MODEL_PRIORITY=gpt-5,llama3-70b,llama3-8b
AI_PROVIDERS=azure-openai,groq
