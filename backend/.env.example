# Telegram Bot Token (obtain from @BotFather)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# ID of the private Telegram Channel where creator posts (e.g. -100123456789)
# If empty, the bot accepts posts directly in private chat for testing/grading!
ADMIN_CHANNEL_ID=

# MongoDB Atlas connection string (Optional: if empty, defaults to local SQLite database)
MONGO_URI=

# Public domain of the deployed backend (Required only if deploying with Webhooks)
# If empty, the bot automatically falls back to secure long-polling mode (great for local run)
WEBHOOK_URL=

# Vercel Deploy Hook URL (Optional: triggers auto-rebuild of portfolio upon new upload)
DEPLOY_HOOK_URL=

# Port to run the server on (defaults to 5000)
PORT=5000
